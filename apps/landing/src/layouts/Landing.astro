---
// The whole landing page, parameterized by locale. Fully static except for
// two tiny inline scripts: a dismissible language suggestion on "/" and
// persisting an explicit language choice (mirrors the app's follow-system
// behavior with a manual override).
import {
  DICTS,
  FONT_STACKS,
  LOCALES,
  localePath,
  type Locale,
} from "../i18n/index";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = DICTS[locale];
const fontStack = FONT_STACKS[locale];
const site = "https://harbly.app";
const github = "https://github.com/harbly-app/harbly";

const OG_LOCALES: Record<Locale, string> = {
  en: "en_US",
  "zh-cn": "zh_CN",
  "zh-tw": "zh_TW",
  ja: "ja_JP",
  ko: "ko_KR",
  es: "es_ES",
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Harbly",
    operatingSystem: "macOS",
    applicationCategory: "ProductivityApplication",
    description: t.description,
    inLanguage: t.htmlLang,
    url: site + localePath(locale),
    image: site + "/og.png",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    license: "https://www.gnu.org/licenses/agpl-3.0.html",
    downloadUrl: github,
    author: { "@type": "Organization", name: "Harbly", url: site },
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Harbly",
    url: site,
    logo: site + "/icon-192.png",
    sameAs: [github],
  },
];

const mockGradients = [
  "linear-gradient(135deg,#EDE9FE,#C4B5FD)",
  "linear-gradient(135deg,#FCE7F3,#F9A8D4)",
  "linear-gradient(135deg,#DCFCE7,#86EFAC)",
  "linear-gradient(135deg,#FEF9C3,#FDE047)",
  "linear-gradient(135deg,#E0F2FE,#7DD3FC)",
  "linear-gradient(135deg,#FFEDD5,#FDBA74)",
];
const mockCards = t.mock.cards.map((c, i) => ({
  ...c,
  g: mockGradients[i % mockGradients.length],
}));
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t.title}</title>
    <meta name="description" content={t.description} />
    <meta name="theme-color" content="#6E56CF" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Harbly" />
    <meta property="og:title" content={t.title} />
    <meta property="og:description" content={t.description} />
    <meta property="og:url" content={site + localePath(locale)} />
    <meta property="og:image" content={site + "/og.png"} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Harbly — local-first HTML knowledge base"
    />
    <meta property="og:locale" content={OG_LOCALES[locale]} />
    {
      LOCALES.filter((l) => l !== locale).map((l) => (
        <meta property="og:locale:alternate" content={OG_LOCALES[l]} />
      ))
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={site + "/og.png"} />
    <link rel="canonical" href={site + localePath(locale)} />
    {
      LOCALES.map((l) => (
        <link
          rel="alternate"
          hreflang={DICTS[l].htmlLang}
          href={site + localePath(l)}
        />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={site + "/"} />
    <link
      rel="preload"
      href="/fonts/manrope-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      // Language handling, following Google's multilingual-site guidance:
      // never auto-redirect off the browser language — hreflang handles SERP
      // routing, and first visits on "/" get a dismissible suggestion banner
      // instead. Only an explicit pick in the switcher (data-lang, persisted)
      // redirects on later visits to "/".
      (function () {
        var KEY = "harbly.landing.lang";
        var DISMISS = "harbly.landing.langBannerDismissed";
        document.addEventListener("click", function (e) {
          var a =
            e.target && e.target.closest && e.target.closest("[data-lang]");
          if (a)
            try {
              localStorage.setItem(KEY, a.getAttribute("data-lang"));
            } catch (_) {}
        });
        if (location.pathname !== "/") return;
        var saved = null;
        var dismissed = null;
        try {
          saved = localStorage.getItem(KEY);
          dismissed = localStorage.getItem(DISMISS);
        } catch (_) {}
        var locales = ["en", "zh-cn", "zh-tw", "ja", "ko", "es"];
        if (saved && locales.indexOf(saved) !== -1) {
          if (saved !== "en") location.replace("/" + saved + "/");
          return;
        }
        if (dismissed) return;
        var nav = (navigator.language || "").toLowerCase();
        var pick = null;
        if (nav.indexOf("zh") === 0)
          pick = /tw|hk|mo|hant/.test(nav) ? "zh-tw" : "zh-cn";
        else if (nav.indexOf("ja") === 0) pick = "ja";
        else if (nav.indexOf("ko") === 0) pick = "ko";
        else if (nav.indexOf("es") === 0) pick = "es";
        if (!pick) return;
        var TEXT = {
          "zh-cn": ["此页面有简体中文版", "前往"],
          "zh-tw": ["此頁面有繁體中文版", "前往"],
          ja: ["このページには日本語版があります", "開く"],
          ko: ["이 페이지는 한국어로도 볼 수 있습니다", "이동"],
          es: ["Esta página está disponible en español", "Ver"],
        }[pick];
        document.addEventListener("DOMContentLoaded", function () {
          var el = document.createElement("div");
          el.className = "lang-banner";
          var span = document.createElement("span");
          span.textContent = TEXT[0];
          var go = document.createElement("a");
          go.href = "/" + pick + "/";
          go.setAttribute("data-lang", pick);
          go.textContent = TEXT[1];
          var x = document.createElement("button");
          x.setAttribute("aria-label", "Dismiss");
          x.textContent = "✕";
          x.addEventListener("click", function () {
            try {
              localStorage.setItem(DISMISS, "1");
            } catch (_) {}
            el.remove();
          });
          el.append(span, go, x);
          document.body.prepend(el);
        });
      })();
    </script>
  </head>

  <body style={`font-family:${fontStack}`}>
    <header class="nav">
      <div class="nav-inner container">
        <a class="brand" href="#top">
          <span class="brand-mark">&lt;/&gt;</span>
          <span class="brand-name">Harbly</span>
        </a>
        <nav class="nav-links">
          <a href="#features">{t.nav.features}</a>
          <a href="#how">{t.nav.how}</a>
        </nav>
        <details class="lang">
          <summary aria-label="Language">🌐 {t.langName}</summary>
          <div class="lang-menu">
            {
              LOCALES.map((l) => (
                <a
                  href={localePath(l)}
                  data-lang={l}
                  class={l === locale ? "current" : ""}
                >
                  {DICTS[l].langName}
                </a>
              ))
            }
          </div>
        </details>
        <a class="btn primary sm" href="#cta"
          >{t.nav.download} <span class="soon">{t.nav.soon}</span></a
        >
      </div>
    </header>

    <main id="top">
      <section class="hero">
        <div class="container">
          <div class="chips">
            {t.chips.map((c) => <span class="chip">{c}</span>)}
          </div>
          <h1>{t.hero.h1Pre}<em>{t.hero.h1Em}</em>{t.hero.h1Post}</h1>
          <p class="lede">{t.hero.lede}</p>
          <div class="cta-row">
            <a class="btn primary" href="#cta"
              >{t.hero.ctaPrimary} <span class="soon">{t.nav.soon}</span></a
            >
            <a class="btn ghost" href="#features">{t.hero.ctaSecondary}</a>
          </div>
          <p class="trust">{t.hero.trust}</p>

          <div class="mock" role="img" aria-label={t.mock.aria}>
            <div class="mock-bar">
              <span class="dot r"></span><span class="dot y"></span><span
                class="dot g"></span>
              <div class="mock-search">{t.mock.search}</div>
              <span class="mock-bar-pad"></span>
            </div>
            <div class="mock-body">
              <aside class="mock-side">
                <div class="mock-label">{t.mock.locations}</div>
                <div class="mock-item">
                  📥 {t.mock.inbox}
                  <span class="badge">1</span>
                </div>
                <div class="mock-item active">📁 {t.mock.folderActive}</div>
                <div class="mock-item sub">📁 {t.mock.folderSub}</div>
                <div class="mock-item">📁 {t.mock.folderB}</div>
                <div class="mock-label">{t.mock.tagsLabel}</div>
                <div class="mock-item">
                  <span class="tagdot" style="background:#EF4444"></span>{
                    t.mock.tagA
                  }
                </div>
                <div class="mock-item">
                  <span class="tagdot" style="background:#6E56CF"></span>{
                    t.mock.tagB
                  }
                </div>
              </aside>
              <div class="mock-grid">
                {
                  mockCards.map((c) => (
                    <div class="mock-card">
                      <div class="mock-thumb" style={`background:${c.g}`} />
                      <div class="mock-card-body">
                        <div class="mock-title">{c.t}</div>
                        <div class="mock-meta">{c.m}</div>
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="features" class="features">
        <div class="container">
          <h2>{t.features.h2}</h2>
          <p class="section-sub">{t.features.sub}</p>
          <div class="feature-grid">
            {
              t.features.items.map((f) => (
                <div class="feature-card">
                  <div class={f.kbd ? "f-icon kbd" : "f-icon"}>{f.icon}</div>
                  <h3>{f.title}</h3>
                  <p>{f.desc}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section id="how" class="how">
        <div class="container">
          <h2>{t.how.h2}</h2>
          <div class="steps">
            {
              t.how.steps.map((s, i) => (
                <div class="step">
                  <div class="step-n">{String(i + 1).padStart(2, "0")}</div>
                  <h3>{s.title}</h3>
                  <p>{s.desc}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section id="cta" class="cta-band">
        <div class="container">
          <h2>{t.cta.h2}</h2>
          <p class="section-sub">{t.cta.sub}</p>
          <a class="btn primary lg" href="#top"
            >{t.cta.btn} <span class="soon">{t.nav.soon}</span></a
          >
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="footer-inner container">
        <div class="brand">
          <span class="brand-mark">&lt;/&gt;</span>
          <span class="brand-name">Harbly</span>
          <span class="footer-tag">{t.footer.tag}</span>
        </div>
        <div class="footer-meta">
          <a href="https://github.com/harbly-app/harbly">GitHub</a> · {
            t.footer.meta
          }
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* Self-hosted variable Manrope, latin subset only — CJK text falls through
   * to the system stacks in FONT_STACKS. */
  @font-face {
    font-family: Manrope;
    font-style: normal;
    font-weight: 200 800;
    font-display: swap;
    src: url("/fonts/manrope-var.woff2") format("woff2");
    unicode-range:
      U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC,
      U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193,
      U+2212, U+2215, U+FEFF, U+FFFD;
  }

  :root {
    --primary: #6e56cf;
    --primary-light: #8570dc;
    --ink: #1a1523;
    --sub: #6f6e77;
    --line: #e4e2e4;
    --paper: #fdfcfd;
    --side: #f4f2f4;
  }

  * {
    box-sizing: border-box;
    margin: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    color: var(--ink);
    background: var(--paper);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  ::selection {
    background: rgba(110, 86, 207, 0.18);
  }

  .container {
    width: min(1080px, 100% - 40px);
    margin-inline: auto;
  }

  /* ---------- Common controls ---------- */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
    white-space: nowrap;
  }
  .btn.sm {
    padding: 8px 16px;
    font-size: 13px;
  }
  .btn.lg {
    padding: 14px 28px;
    font-size: 15px;
  }
  .btn.primary {
    background: var(--primary);
    color: #fff;
    box-shadow: 0 10px 24px -10px rgba(110, 86, 207, 0.55);
  }
  .btn.primary:hover {
    background: var(--primary-light);
    transform: translateY(-1px);
  }
  .btn.ghost {
    border: 1px solid var(--line);
    background: #fff;
    color: var(--ink);
  }
  .btn.ghost:hover {
    border-color: var(--primary);
    color: var(--primary);
  }
  .soon {
    font-size: 10px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.22);
  }

  /* ---------- Language suggestion banner ---------- */
  .lang-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 9px 14px;
    font-size: 13px;
    background: rgba(110, 86, 207, 0.08);
    border-bottom: 1px solid var(--line);
    color: var(--ink);
  }
  .lang-banner a {
    color: var(--primary);
    font-weight: 700;
    text-decoration: none;
  }
  .lang-banner a:hover {
    text-decoration: underline;
  }
  .lang-banner button {
    border: 0;
    background: none;
    color: var(--sub);
    font-size: 13px;
    cursor: pointer;
    padding: 2px 6px;
  }

  /* ---------- Navigation ---------- */
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(253, 252, 253, 0.82);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 60px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    color: var(--ink);
  }
  .brand-mark {
    width: 28px;
    height: 28px;
    border-radius: 9px;
    background: var(--primary);
    color: #fff;
    display: grid;
    place-items: center;
    font-size: 11px;
    font-weight: 800;
    font-family: ui-monospace, Menlo, monospace;
  }
  .brand-name {
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 0.2px;
  }
  .nav-links {
    display: flex;
    gap: 20px;
    margin-left: 8px;
    margin-right: auto;
  }
  .nav-links a {
    font-size: 13.5px;
    color: var(--sub);
    text-decoration: none;
    font-weight: 500;
  }
  .nav-links a:hover {
    color: var(--ink);
  }

  /* ---------- Language switcher ---------- */
  .lang {
    position: relative;
    margin-left: auto;
  }
  .nav-links + .lang {
    margin-left: 0;
  }
  .lang summary {
    list-style: none;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    color: var(--sub);
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid transparent;
    white-space: nowrap;
    user-select: none;
  }
  .lang summary::-webkit-details-marker {
    display: none;
  }
  .lang summary:hover,
  .lang[open] summary {
    color: var(--ink);
    border-color: var(--line);
    background: #fff;
  }
  .lang-menu {
    position: absolute;
    right: 0;
    top: calc(100% + 6px);
    min-width: 132px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 12px;
    box-shadow: 0 18px 40px -20px rgba(26, 21, 35, 0.28);
    padding: 6px;
    display: grid;
  }
  .lang-menu a {
    font-size: 13px;
    color: var(--ink);
    text-decoration: none;
    padding: 7px 10px;
    border-radius: 8px;
  }
  .lang-menu a:hover {
    background: var(--side);
  }
  .lang-menu a.current {
    color: var(--primary);
    font-weight: 700;
  }

  /* ---------- Hero ---------- */
  .hero {
    padding: clamp(56px, 9vw, 110px) 0 clamp(64px, 9vw, 110px);
    text-align: center;
    background: radial-gradient(
      820px 420px at 50% -8%,
      rgba(110, 86, 207, 0.12),
      transparent 70%
    );
  }
  .chips {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 22px;
  }
  .chip {
    font-size: 12px;
    font-weight: 600;
    color: var(--sub);
    border: 1px solid var(--line);
    background: #fff;
    padding: 5px 12px;
    border-radius: 999px;
  }
  h1 {
    font-size: clamp(34px, 6.5vw, 58px);
    font-weight: 900;
    line-height: 1.16;
    letter-spacing: -0.5px;
  }
  h1 em {
    font-style: normal;
    color: var(--primary);
  }
  .lede {
    max-width: 640px;
    margin: 18px auto 0;
    font-size: clamp(15px, 2.1vw, 17.5px);
    color: var(--sub);
  }
  .cta-row {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 30px;
  }
  .trust {
    margin-top: 14px;
    font-size: 12.5px;
    color: var(--sub);
  }

  /* ---------- App window mockup ---------- */
  .mock {
    max-width: 880px;
    margin: clamp(40px, 6vw, 64px) auto 0;
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
    background: var(--paper);
    box-shadow: 0 32px 80px -32px rgba(110, 86, 207, 0.3);
    text-align: left;
  }
  .mock-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    height: 42px;
    padding: 0 14px;
    border-bottom: 1px solid var(--line);
    background: #fbfafc;
  }
  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .dot.r {
    background: #ff5f57;
  }
  .dot.y {
    background: #febc2e;
  }
  .dot.g {
    background: #28c840;
  }
  .mock-search {
    margin: 0 auto;
    width: min(300px, 46%);
    font-size: 11.5px;
    color: var(--sub);
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 5px 14px;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .mock-bar-pad {
    width: 47px;
  }
  .mock-body {
    display: grid;
    grid-template-columns: 196px 1fr;
  }
  .mock-side {
    background: var(--side);
    border-right: 1px solid var(--line);
    padding: 12px 10px;
    font-size: 12.5px;
  }
  .mock-label {
    font-size: 10.5px;
    color: var(--sub);
    padding: 8px 8px 4px;
    font-weight: 700;
  }
  .mock-item {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 5.5px 8px;
    border-radius: 7px;
    color: var(--ink);
  }
  .mock-item.sub {
    padding-left: 26px;
  }
  .mock-item.active {
    background: rgba(110, 86, 207, 0.12);
    color: var(--primary);
    font-weight: 600;
  }
  .badge {
    margin-left: auto;
    font-size: 10px;
    font-weight: 700;
    background: var(--primary);
    color: #fff;
    border-radius: 999px;
    padding: 1px 6px;
  }
  .tagdot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    display: inline-block;
  }
  .mock-grid {
    padding: 14px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    align-content: start;
  }
  .mock-card {
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
  }
  .mock-thumb {
    aspect-ratio: 16 / 10;
  }
  .mock-card-body {
    padding: 8px 10px 9px;
  }
  .mock-title {
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .mock-meta {
    font-size: 10.5px;
    color: var(--sub);
    margin-top: 2px;
  }

  /* ---------- Features ---------- */
  .features {
    padding: clamp(64px, 9vw, 110px) 0;
  }
  h2 {
    font-size: clamp(24px, 4vw, 34px);
    font-weight: 900;
    text-align: center;
    letter-spacing: -0.3px;
  }
  .section-sub {
    text-align: center;
    color: var(--sub);
    margin-top: 10px;
    font-size: 15px;
  }
  .feature-grid {
    margin-top: clamp(32px, 5vw, 48px);
    display: grid;
