{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harbly",
  "version": "0.1.0",
  "identifier": "com.zeyu.harbly",
  "build": {
    "beforeDevCommand": "node scripts/prepare-sidecar.mjs && node scripts/generate-notices.mjs && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/prepare-sidecar.mjs && node scripts/generate-notices.mjs && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Harbly",
        "width": 1280,
        "height": 840,
        "minWidth": 980,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 24
        },
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "externalBin": ["binaries/harbly-mcp"],
    "resources": ["resources/THIRD-PARTY-NOTICES.md"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
