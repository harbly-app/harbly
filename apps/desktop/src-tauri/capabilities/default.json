{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "主窗口默认能力；缩略图隐藏窗口不授予任何 IPC 权限",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "drag:default",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize"
  ]
}
